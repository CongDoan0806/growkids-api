generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model users {
  id                 String          @id @default(uuid())
  fullName           String
  email              String          @unique
  password           String
  languagePreference String?
  refreshToken       String?
  createdAt          DateTime        @default(now())
  children           children[]
  conversations      conversations[]
}

model children {
  child_id                String                    @id @default(uuid())
  user_id                 String
  full_name               String                    @db.VarChar
  birth_date              DateTime?                 @db.Date
  gender                  String?                   @db.VarChar
  created_at              DateTime                  @default(now())
  users                   users                     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  learning_logs           learning_logs[]
  object_recognition_logs object_recognition_logs[]
  routines                routines[]
}

model routine_time_blocks {
  block_id      String   @id @default(uuid())
  routine_id    String
  activity_type String   @db.VarChar
  start_time    String
  end_time      String
  description   String?  @db.VarChar
  routines      routines @relation(fields: [routine_id], references: [routine_id], onDelete: Cascade)
}

model routines {
  routine_id          String                @id @default(uuid())
  child_id            String
  routine_name        String                @db.VarChar
  is_active           Boolean               @default(true)
  created_by_ai       Boolean               @default(false)
  created_at          DateTime              @default(now())
  updated_at          DateTime
  golden_time_slots   golden_time_slots[]
  routine_time_blocks routine_time_blocks[]
  children            children              @relation(fields: [child_id], references: [child_id], onDelete: Cascade)
}

model golden_time_slots {
  slot_id          String          @id @default(uuid())
  routine_id       String
  slot_type        String
  start_time       String
  duration_minutes Int
  context          String?
  suggestions      Json?
  is_active        Boolean         @default(true)
  created_at       DateTime        @default(now())
  routine       routines        @relation(fields: [routine_id], references: [routine_id], onDelete: Cascade)
  learning_logs    learning_logs[]

  @@index([routine_id])
}

model conversations {
  conversation_id   String   @id @default(uuid())
  user_id           String
  conversation_type String
  input_text        String
  output_text       String?
  phonetic          String?
  suggestions       Json?
  created_at        DateTime @default(now())
  users             users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model learning_logs {
  learning_log_id       Int                @id @default(autoincrement())
  child_id              String
  mini_song_id          String?
  story_id              Int?
  slot_id               String?
  progress_percent      Int?
  time_spent_seconds    Int?
  last_position_seconds Int?
  is_completed          Boolean            @default(false)
  started_at            DateTime           @default(now())
  completed_at          DateTime?
  last_accessed_at      DateTime           @default(now())
  children              children           @relation(fields: [child_id], references: [child_id], onDelete: Cascade)
  mini_songs            mini_songs?        @relation(fields: [mini_song_id], references: [mini_song_id])
  golden_time_slots     golden_time_slots? @relation(fields: [slot_id], references: [slot_id])
  stories               stories?           @relation(fields: [story_id], references: [story_id])

  @@index([child_id])
  @@index([mini_song_id])
  @@index([slot_id])
  @@index([story_id])
}

model stories {
  story_id         Int              @id @default(autoincrement())
  topic_id         Int?
  title            String           @db.VarChar
  age_min          Int?
  age_max          Int?
  duration_seconds Int?
  cover_image_url  String?          @db.VarChar
  is_active        Boolean          @default(true)
  created_at       DateTime         @default(now())
  learning_logs    learning_logs[]
  story_segments   story_segments[]

  @@index([topic_id])
}

model story_segments {
  segment_id       Int      @id @default(autoincrement())
  story_id         Int
  segment_order    Int
  content_text     String?
  image_url        String?  @db.VarChar
  audio_url        String?  @db.VarChar
  interaction_type String?  @db.VarChar
  created_at       DateTime @default(now())
  stories          stories  @relation(fields: [story_id], references: [story_id], onDelete: Cascade)

  @@index([story_id])
}

model object_recognition_logs {
  recognition_id  Int      @id @default(autoincrement())
  child_id        String
  detected_object String   @db.VarChar
  created_at      DateTime @default(now())
  children        children @relation(fields: [child_id], references: [child_id], onDelete: Cascade)

  @@index([child_id])
}

model mini_songs {
  mini_song_id         String          @id @default(uuid())
  title                String          @unique @db.VarChar(255)
  thumbnail            String?         @db.VarChar(500)
  duration             Float?
  views                Int             @default(0)
  video_url            String?         @db.VarChar(500)
  category             String?
  created_at           DateTime        @default(now())
  is_completed         Boolean         @default(false)
  last_listen_position Float           @default(0)
  learning_logs        learning_logs[]
  song_lyrics          song_lyrics[]
}

model song_lyrics {
  id         String     @id @default(uuid())
  song_id    String
  line_order Int
  lyric_text String?
  phonetic   String?
  start_time Float?
  mini_songs mini_songs @relation(fields: [song_id], references: [mini_song_id], onDelete: Cascade)

  @@index([song_id])
}
