generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model users {
  id                 String     @id @default(uuid())
  fullName           String
  email              String     @unique
  password           String
  languagePreference String?
  refreshToken       String?
  createdAt          DateTime   @default(now())
  children           children[]
}

model children {
  child_id   String     @id @default(uuid())
  user_id    String
  full_name  String     @db.VarChar
  birth_date DateTime?  @db.Date
  gender     String?    @db.VarChar
  created_at DateTime   @default(now())
  users      users      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  routines   routines[]
}

model routine_time_blocks {
  block_id      String   @id @default(uuid())
  routine_id    String
  activity_type String   @db.VarChar
  start_time    String
  end_time      String
  description   String?  @db.VarChar
  routines      routines @relation(fields: [routine_id], references: [routine_id], onDelete: Cascade)
}

model routines {
  routine_id          String                @id @default(uuid())
  child_id            String
  routine_name        String                @db.VarChar
  is_active           Boolean               @default(true)
  created_by_ai       Boolean               @default(false)
  created_at          DateTime              @default(now())
  updated_at          DateTime
  routine_time_blocks routine_time_blocks[]
  children            children              @relation(fields: [child_id], references: [child_id], onDelete: Cascade)
}
